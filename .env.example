# ============================================
# Variables de Entorno - SeparApp
# ============================================
# Copiar este archivo como .env y completar con tus credenciales

# ============================================
# SUPABASE
# ============================================
# Obtener de: https://supabase.com/dashboard/project/[PROJECT-ID]/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# STRIPE
# ============================================
# Obtener de: https://dashboard.stripe.com/test/apikeys

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# OPENAI
# ============================================
# Obtener de: https://platform.openai.com/api-keys
# Usado para: OCR (Vision API) y filtro de mensajes (GPT-4o-mini)

EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-...

# ============================================
# FIREBASE / GOOGLE SIGN-IN
# ============================================
# Obtener de: https://console.firebase.google.com

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=...apps.googleusercontent.com

# ============================================
# EAS / EXPO
# ============================================
# Obtener de: https://expo.dev

EXPO_PUBLIC_EAS_PROJECT_ID=your-project-id
